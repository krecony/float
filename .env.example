# Copy to .env at repo root and fill from your Supabase project dashboard.
# Mobile (Expo) reads EXPO_PUBLIC_* ; terminal (Vite) reads VITE_*.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: marketing site GitHub link
VITE_GITHUB_REPO_URL=https://github.com/your-org/grouppay

# Demo name login (maps to synthetic email @grouppay.demo — same value for Expo and Vite)
EXPO_PUBLIC_DEMO_AUTH_PASSWORD=grouppay-demo
VITE_DEMO_AUTH_PASSWORD=grouppay-demo

# Apply schema: nix develop && supabase link && supabase db push
